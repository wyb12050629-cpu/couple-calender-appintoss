# ─────────────────────────────────────────────────────────────
# 우리 사이 — 환경변수 템플릿
# ─────────────────────────────────────────────────────────────
# 이 파일은 깃에 올라가는 템플릿입니다. 절대 실제 값을 적지 마세요.
# 실제 값은 .env.local 에만 입력하고, .env.local 은 .gitignore에 들어있습니다.
# 모든 값은 유빈님이 직접 채워넣으세요. (Claude는 구조만 작성)
# ─────────────────────────────────────────────────────────────


# ───── 1. 앱인토스 mTLS 인증서 ─────────────────────────────────
# /mnt/mTLS_인증서_20260506/ 의 .crt, .key 파일을 BASE64로 인코딩해서 한 줄로 넣기.
# 인코딩 명령어 (터미널):
#   base64 -i 우리사이_public.crt | tr -d '\n' | pbcopy   (macOS)
#   base64 -w 0 우리사이_public.crt                       (Linux)
APPINTOSS_CLIENT_CERT_BASE64=
APPINTOSS_CLIENT_KEY_BASE64=

# 로컬 개발 시 파일 경로로 쓸 수도 있음 (둘 중 하나만 채우면 됨)
# 깃에 .pem 파일 자체는 절대 커밋 금지
APPINTOSS_CLIENT_CERT_PATH=
APPINTOSS_CLIENT_KEY_PATH=


# ───── 2. 앱인토스 API Client ID / Secret ─────────────────────
# cert.support@toss.im 으로 받은 값
APPINTOSS_CLIENT_ID=
APPINTOSS_CLIENT_SECRET=


# ───── 3. 앱인토스 응답 복호화 (AES-256-GCM) ──────────────────
# 토스에서 추가로 발급받은 두 값. /login-me 응답 PII 필드 복호화 시 사용.
# 우리 사이는 /login-me 안 쓸 가능성 높지만, 일단 보관.
# DECRYPTION_KEY는 BASE64 문자열, AAD는 일반 문자열로 받았을 가능성이 큼.
APPINTOSS_DECRYPTION_KEY_BASE64=
APPINTOSS_AAD_STRING=


# ───── 4. 앱인토스 토스 API 베이스 URL ────────────────────────
# referrer = 'DEFAULT' 일 때 (운영)
APPINTOSS_AUTH_API_BASE=https://apps-in-toss-api.toss.im/api-partner/v1/apps-in-toss/user/oauth2

# referrer = 'SANDBOX' 일 때 (개발/테스트) — 토스 측 안내문 확인 후 입력
APPINTOSS_AUTH_API_BASE_SANDBOX=


# ───── 5. Firebase Admin SDK (서버용) ─────────────────────────
# Firebase Console > 프로젝트 설정 > 서비스 계정 > "새 비공개 키 생성"으로 받은 .json 파일.
# 통째로 BASE64 인코딩해서 한 줄로 넣는 게 편함:
#   base64 -i firebase-adminsdk.json | tr -d '\n' | pbcopy
FIREBASE_ADMIN_SDK_BASE64=

# 또는 .json 안의 3개 핵심 값을 따로 분리해서 넣어도 됨 (둘 중 하나만 선택)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# ───── 6. Firebase 웹 SDK (클라이언트 노출 가능 - NEXT_PUBLIC_) ─
# Firebase Console > 프로젝트 설정 > 일반 > 내 앱 > 웹 앱의 firebaseConfig 값
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=


# ───── 7. 기존 데모 (Supabase) — 절대 건드리지 말 것 ──────────
# 기존 yubin/munsung 개인 데이터 연결용. 공개판은 Firebase로 분리.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=


# ───── 8. 푸시 알림 (VAPID) — 추후 ─────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ───── 9. 토스 Vercel 함수 URL (NEXT_PUBLIC_*: 빌드 시 박힘) ─────
# 인증 토큰 발급 함수
NEXT_PUBLIC_TOSS_AUTH_FN_URL=https://couple-calender-appintoss.vercel.app/api/auth/toss
# 스마트 메시지 발송 함수 (일정 등록 시 파트너에게 푸시)
NEXT_PUBLIC_TOSS_NOTIFY_FN_URL=https://couple-calender-appintoss.vercel.app/api/notify/send
