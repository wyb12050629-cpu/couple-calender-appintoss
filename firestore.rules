rules_version = '2';

// 우리 사이 — Firestore 보안 규칙
//
// 컬렉션 구조:
//   /users/{uid}
//   /couples/{coupleId}
//   /couples/{coupleId}/events/{eventId}
//   /couples/{coupleId}/gratitudes/{gratitudeId}
//   /inviteCodes/{code}
//
// 핵심 원칙
//  - 모든 쓰기는 인증된 요청만 허용 (Firebase Auth uid 필수).
//  - 커플 도큐먼트 / 하위 컬렉션은 members 배열에 자기 uid가 있어야만 RW.
//  - 파트너 연결 트랜잭션(acceptInvite)은 양쪽 users 문서를 동시에 수정해야 하므로
//    /users/{uid}는 본인뿐 아니라 "초대 코드를 통해 연결되는 상대방"에게도 제한적으로 쓰기 허용.
//  - inviteCodes는 발급자만 생성, 코드 단건 조회는 인증된 사용자 누구나 (수락에 필요).

service cloud.firestore {
  match /databases/{database}/documents {

    // ── 공통 헬퍼 ──
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isMemberOfCouple(coupleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && uid() in get(/databases/$(database)/documents/couples/$(coupleId)).data.members;
    }

    // ──────────────────────────────────────────────
    // /users/{uid} — 자기 프로필
    // ──────────────────────────────────────────────
    match /users/{userId} {
      // 읽기: 본인 또는 같은 커플의 파트너만
      allow read: if isSignedIn() && (
        uid() == userId
        // 파트너가 내 프로필을 읽으려면, 내 partnerUid가 그 사람이어야 함
        || resource.data.partnerUid == uid()
      );

      // 본인은 자기 문서 자유롭게 RW
      allow create: if isSignedIn() && uid() == userId;
      allow update, delete: if isSignedIn() && uid() == userId;

      // 예외: acceptInvite 트랜잭션에서 상대 user 문서에 partnerUid/coupleId/coupleStatus만 박는 경우 허용
      // (immutable 필드는 변경 못 하게 keys() 제한)
      allow update: if isSignedIn()
        && uid() != userId
        && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['partnerUid', 'coupleId', 'coupleStatus'])
        && request.resource.data.partnerUid == uid();
    }

    // ──────────────────────────────────────────────
    // /couples/{coupleId}
    // ──────────────────────────────────────────────
    match /couples/{coupleId} {
      // 읽기: 멤버만
      allow read: if isSignedIn() && uid() in resource.data.members;

      // 생성: 본인이 inviter일 때만, 초기 members는 [본인]
      allow create: if isSignedIn()
        && request.resource.data.inviterUid == uid()
        && request.resource.data.members.size() == 1
        && request.resource.data.members[0] == uid()
        && request.resource.data.status == 'pending';

      // 수정: 트랜잭션 두 가지 케이스만 허용
      //   1) 본인이 멤버 (정상 갱신)
      //   2) acceptInvite — 아직 멤버가 아니지만 초대 받은 사람이 본인을 추가
      allow update: if isSignedIn() && (
        uid() in resource.data.members
        || (
          // pending → connected 전환 + 자기 자신을 추가
          resource.data.status == 'pending'
          && request.resource.data.status == 'connected'
          && request.resource.data.inviteeUid == uid()
          && request.resource.data.members.size() == 2
          && uid() in request.resource.data.members
        )
      );

      // 삭제는 클라이언트에서 금지 (운영 콘솔/Function에서만)
      allow delete: if false;

      // ────── 하위: events ──────
      match /events/{eventId} {
        allow read:   if isMemberOfCouple(coupleId);
        allow create: if isMemberOfCouple(coupleId)
          && request.resource.data.creatorUid is string;
        allow update, delete: if isMemberOfCouple(coupleId);
      }

      // ────── 하위: gratitudes ──────
      match /gratitudes/{gid} {
        allow read:   if isMemberOfCouple(coupleId);
        allow create: if isMemberOfCouple(coupleId)
          && request.resource.data.fromUid == uid();
        // 본인이 보낸 카드만 수정/삭제
        allow update, delete: if isMemberOfCouple(coupleId)
          && resource.data.fromUid == uid();
      }
    }

    // ──────────────────────────────────────────────
    // /inviteCodes/{code}
    // ──────────────────────────────────────────────
    match /inviteCodes/{code} {
      // 누구나(=인증된 사용자) 단건 조회 가능 — 수락에 필요
      allow get: if isSignedIn();
      // 목록 쿼리는 금지
      allow list: if false;

      // 생성: createCoupleWithInvite 트랜잭션 — 본인이 inviter
      allow create: if isSignedIn()
        && request.resource.data.inviterUid == uid()
        && request.resource.data.status == 'pending';

      // 수정: pending → used 전환만 허용 (acceptInvite)
      allow update: if isSignedIn()
        && resource.data.status == 'pending'
        && request.resource.data.status == 'used';

      allow delete: if false;
    }
  }
}
